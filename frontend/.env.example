# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Your personal Telegram chat ID (for admin notifications)
# Message @userinfobot on Telegram to get this
TELEGRAM_ADMIN_CHAT_ID=your_personal_telegram_chat_id

# ── Telegram Database (private GROUP) ─────────────────────────────────────────
# Create a private GROUP, add bot as admin (with pin + edit permissions)
# Chat ID will be a negative number like -1001234567890
# Get it from @getidsbot or Telegram API
TELEGRAM_DB_CHAT_ID=-1001234567890

# ── Telegram Storage (private CHANNEL) ────────────────────────────────────────
# Create a SEPARATE private CHANNEL for storing book files (PDF, EPUB, covers)
# Add bot as admin with "post messages" permission
# Channel ID also starts with -100...
TELEGRAM_STORAGE_CHANNEL_ID=-1009876543210

# JWT — change to a random 32+ character string
JWT_SECRET=quantxbooks-jwt-secret-change-in-production-min-32-chars

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=QuantXBooks

# Cosmofeed Payment
COSMOFEED_API_KEY=your_cosmofeed_api_key
COSMOFEED_WEBHOOK_SECRET=your_webhook_secret

# Setup secret (used for first-time DB initialization)
SETUP_SECRET=your_random_setup_secret

# OTP settings
OTP_EXPIRY_MINUTES=10

# NODE_ENV
NODE_ENV=development
